class Stock {

    public static void main(String args[]) {

        int price[] = {1, 2, 100};

        int max = 0;
        int profit = 0;

        for(int i = price.length-1; i >= 0; i--) {

            if(price[i] > max)
                max = price[i];
            else
                profit += max - price[i];
        }

        System.out.println("Maximum Profit = " + profit);
    }
}
