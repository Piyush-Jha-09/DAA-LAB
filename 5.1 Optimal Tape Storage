import java.util.*;
public class Storage {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of programs: ");
        int n = sc.nextInt();

        int[] a = new int[n];

        System.out.println("Enter lengths of programs:");
        for (int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }

        Arrays.sort(a);

        int sum = 0, total = 0;

        for (int i = 0; i < n; i++) {
            sum += a[i];
            total += sum;
        }
        System.out.println("Mean Retrieval Time (MRT) = " + total);
    }
}
