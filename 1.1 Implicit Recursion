import java.util.*;

class IR {
    static int findLargest(List<Integer> a) {
        return Collections.max(a);
    }

    static int findSecondLargest(List<Integer> a) {
        int x = findLargest(a);
        a.remove(Integer.valueOf(x));
        return findLargest(a);
    }

    public static void main(String[] args) {
        List<Integer> a = new ArrayList<>(Arrays.asList(1,2,3,4,5));
        System.out.println(findSecondLargest(a));
    }
}
