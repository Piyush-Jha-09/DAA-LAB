class BFS {
    public static void main(String args[]) {
        int g[][] = {
            {1,2},    // Neighbors of 0
            {3,4},    // Neighbors of 1
            {},       // Neighbors of 2
            {},       // Neighbors of 3
            {}        // Neighbors of 4
        };

        boolean v[] = new boolean[5];
        int q[] = new int[5];
        int f = 0, r = 0;

        q[r++] = 0;
        v[0] = true;

        System.out.print("BFS: ");

        while(f < r) {
            int x = q[f++];
            System.out.print(x + " ");

            for(int i = 0; i < g[x].length; i++) {
                int n = g[x][i];
                if(!v[n]) {
                    v[n] = true;
                    q[r++] = n;
                }
            }
        }
    }
}
