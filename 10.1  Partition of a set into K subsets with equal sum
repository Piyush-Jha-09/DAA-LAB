class Partition {

    static boolean solve(int a[], boolean v[], int sum, int target, int k, int i) {

        if(k==1) return true;

        if(sum==target)
            return solve(a,v,0,target,k-1,0);

        for(int j=i;j<a.length;j++) {
            if(!v[j] && sum+a[j]<=target) {
                v[j]=true;

                if(solve(a,v,sum+a[j],target,k,j+1))
                    return true;

                v[j]=false;
            }
        }
        return false;
    }

    public static void main(String args[]) {

        int a[]={2,1,4,5,6};
        int k=3,sum=0;

        for(int x:a) sum+=x;

        if(sum%k!=0)
            System.out.println("No");
        else
            System.out.println(solve(a,new boolean[a.length],0,sum/k,k,0) ? "Yes" : "No");
    }
}
